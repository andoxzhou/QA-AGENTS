        {
          "name": "Quote - Panora - 主币<>代币 (APT → USDC)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.variables.set('requestId', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Panora 主币<>代币 - HTTP 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "pm.test('Panora 主币<>代币 - 业务码 0', function () {",
                  "  pm.expect(json.code).to.eql(0);",
                  "});",
                  "",
                  "pm.test('Panora 主币<>代币 - 返回包含 Panora 有效报价', function () {",
                  "  var data = json.data || [];",
                  "  var item = data.find(function (x) {",
                  "    var p = x && x.info && x.info.provider;",
                  "    return p && String(p).toLowerCase().indexOf('panora') >= 0;",
                  "  });",
                  "  pm.expect(item, 'data 中不存在 Panora 条目').to.not.be.undefined;",
                  "  pm.expect(item.errorMessage, 'Panora 条目携带 errorMessage: ' + item.errorMessage).to.be.oneOf([undefined, null, '']);",
                  "  var hasQuote = item.toAmount || item.fromAmount || (item.info && item.info.toAmount);",
                  "  pm.expect(hasQuote, 'Panora 条目无有效报价金额').to.be.ok;",
                  "});"
                ]
              }
            }
