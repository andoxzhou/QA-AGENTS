                  "  \"X-Onekey-Request-Theme\": \"light\",",
                  "  \"X-Onekey-Request-Platform\": \"desktop-macosStore\",",
                  "  \"X-Onekey-Request-Version\": \"6.1.0\",",
                  "  \"X-Onekey-Request-Build-Number\": \"2026022727\"",
                  "};",
                  "",
                  "const buildHeaders = {",
                  "  \"accept\": \"application/json, text/plain, */*\",",
                  "  \"content-type\": \"application/json\",",
                  "  \"X-Onekey-Request-ID\": pm.variables.replaceIn(\"{{$guid}}\"),",
                  "  \"X-Onekey-Request-Currency\": \"usd\",",
                  "  \"X-Onekey-Request-Locale\": \"en\",",
                  "  \"X-Onekey-Request-Theme\": \"light\",",
                  "  \"X-Onekey-Request-Platform\": \"desktop-macosStore\",",
                  "  \"X-Onekey-Request-Version\": \"6.1.0\",",
                  "  \"X-Onekey-Request-Build-Number\": \"2026022727\",",
                  "  \"X-Onekey-Wallet-Type\": \"hd\"",
                  "};",
                  "",
                  "function buildQuery(params) {",
                  "  return Object.entries(params)",
                  "    .filter(function(kv){ return kv[1]!==undefined && kv[1]!==null; })",
                  "    .map(function(kv){ return encodeURIComponent(kv[0]) + '=' + encodeURIComponent(String(kv[1])); })",
                  "    .join('&');",
                  "}",
                  "",
                  "function runCase(i){",
                  "  if(i >= testCases.length){",
                  "    console.log(\"🎉 1inchFusion 代币<>代币 用例完成\");",
                  "    return;",
                  "  }",
                  "  var c = testCases[i];",
                  "  var caseName = c.name;",
                  "  console.log(\"\\n===== [\" + caseName + \"] 开始 =====\");",
                  "",
                  "  pm.sendRequest({",
                  "    url: QUOTE_URL + '?' + buildQuery(c.quoteParams),",
                  "    method: 'GET',",
                  "    header: Object.entries(quoteHeaders).map(function(e){ return { key: e[0], value: String(e[1]) }; })",
                  "  }, function(err, res){",
                  "    if (err) {",
                  "      pm.test('['+caseName+'] quote 请求失败', function(){ pm.expect.fail(err.toString()); });",
                  "      runCase(i+1);",
                  "      return;",
                  "    }",
                  "    var code = res.code || res.status;",
                  "    pm.test('['+caseName+'] quote HTTP 200', function(){ pm.expect(code).to.equal(200); });",
                  "    var json = res.json();",
                  "    pm.test('['+caseName+'] quote 业务码 0', function(){ pm.expect(json.code).to.eql(0); });",
                  "    var d = json.data || [];",
                  "    var fusionEntry = d.find(function(x){",
                  "      return x.info && x.info.provider && String(x.info.provider).toLowerCase().indexOf('fusion') >= 0;",
                  "    });",
                  "    pm.test('['+caseName+'] Fusion 有效报价', function(){",
                  "      pm.expect(fusionEntry, '未找到 info.provider 含 fusion 的条目').to.be.ok;",
                  "      pm.expect(fusionEntry.errorMessage, 'Fusion 条目携带 errorMessage: ' + (fusionEntry && fusionEntry.errorMessage)).to.be.oneOf([undefined, null, '']);",
                  "      var hasQuote = fusionEntry.toAmount || fusionEntry.fromAmount || (fusionEntry.info && fusionEntry.info.toAmount);",
                  "      pm.expect(hasQuote, 'Fusion 条目无有效报价金额').to.be.ok;",
                  "    });",
                  "    var ctx = fusionEntry && fusionEntry.quoteResultCtx;",
                  "    pm.test('['+caseName+'] quoteResultCtx 存在', function(){ pm.expect(ctx, 'quoteResultCtx 缺失').to.be.ok; });",
                  "",
                  "    var buildBody = Object.assign({}, c.buildBase, {",
                  "      protocol: 'Swap',",
                  "      provider: 'Swap1inch',",
                  "      userAddress: '0x4EF880525383ab4E3d94b7689e3146bF899A296e',",
                  "      receivingAddress: '0x4EF880525383ab4E3d94b7689e3146bF899A296e',",
                  "      slippagePercentage: 0.5,",
                  "      kind: 'sell',",
                  "      walletType: 'hd',",
                  "      quoteResultCtx: ctx",
                  "    });",
                  "",
                  "    console.log('['+caseName+'] build body:', buildBody);",
                  "",
                  "    pm.sendRequest({",
                  "      url: BUILD_URL,",
