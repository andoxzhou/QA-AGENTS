              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "/**",
                  " * 1inch Fusion 代币→代币：quoteResultCtx -> build-tx",
                  " */",
                  "const testCases = [",
                  "  {",
